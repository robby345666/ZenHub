-- Drawing objects pool: {highlight, billboard, line}
local espObjects = {}  -- key = model, value = {hl, bb, line}

local function ClearAllESP()
    for model, obj in pairs(espObjects) do
        pcall(function()
            if obj.hl then obj.hl:Destroy() end
            if obj.bb then obj.bb:Destroy() end
            if obj.line then obj.line:Remove() end
        end)
    end
    espObjects = {}
end

local function GetRootPart(model)
    if model:IsA("BasePart") then return model end
    local hrp = model:FindFirstChild("HumanoidRootPart") or model:FindFirstChildWhichIsA("BasePart")
    return hrp
end

-- Find all brainrot models in workspace by name matching
local function FindBrainrotsInWorkspace()
    local found = {}
    for _, obj in ipairs(workspace:GetDescendants()) do
        if (obj:IsA("Model") or obj:IsA("BasePart")) and #obj.Name > 2 then
            local nl = obj.Name:lower()
            -- look for M/s related values stored on model
            local msChild = obj:FindFirstChild("MS") or obj:FindFirstChild("M/s")
                         or obj:FindFirstChild("MoneyPerSecond") or obj:FindFirstChild("MPS")
                         or obj:FindFirstChild("Value")
            local ms = 0
            if msChild and (msChild:IsA("NumberValue") or msChild:IsA("IntValue")) then
                ms = msChild.Value
            end
            -- Check if name matches a known brainrot pattern
            local looksLikeBrainrot = false
            if nl:find("tralal") or nl:find("sahur") or nl:find("brainrot") or nl:find("los ") or
               nl:find("la ") or nl:find("griffin") or nl:find("pegasus") or nl:find("spyder") or
               nl:find("tung") or nl:find("ino$") or nl:find("edon$") or nl:find("ito$") or
               nl:find("ero$") or nl:find("ella$") or nl:find("illo$") or nl:find("ura$") or
               nl:find("uru$") or ms > 0 then
                looksLikeBrainrot = true
            end
            if looksLikeBrainrot then
                local root = GetRootPart(obj)
                if root then
                    table.insert(found, {model=obj, root=root, name=obj.Name, ms=ms})
                end
            end
        end
    end
    return found
end

local function GetESPColor(ms)
    if ms >= 200 then return Color3.fromRGB(255,50,50)   end  -- red = very high
    if ms >= 100 then return Color3.fromRGB(255,165,0)   end  -- orange
    if ms >= 50  then return Color3.fromRGB(255,255,0)   end  -- yellow
    if ms >= 20  then return Color3.fromRGB(0,200,255)   end  -- cyan
    return Color3.fromRGB(0,255,100)                          -- green = low
end

local camera = workspace.CurrentCamera

local function WorldToViewport(pos)
    local screenPos, onScreen = camera:WorldToViewportPoint(pos)
    return Vector2.new(screenPos.X, screenPos.Y), onScreen, screenPos.Z
end

local function ApplyESPToModel(data)
    local model = data.model
    local root  = data.root
    local ms    = data.ms
    local col   = GetESPColor(ms)

    -- Remove old if exists
    if espObjects[model] then
        pcall(function()
            if espObjects[model].hl  then espObjects[model].hl:Destroy() end
            if espObjects[model].bb  then espObjects[model].bb:Destroy() end
            if espObjects[model].line then espObjects[model].line:Remove() end
        end)
    end

    local obj = {}

    -- BOX using Highlight
    if espBoxOn then
        local ok, hl = pcall(function()
            local h = Instance.new("Highlight")
            h.FillColor = col
            h.OutlineColor = col
            h.FillTransparency = 0.75
            h.OutlineTransparency = 0
            h.Adornee = model:IsA("Model") and model or root
            h.Parent = model:IsA("Model") and model or root
            return h
        end)
        if ok then obj.hl = hl end
    end

    -- LABEL using BillboardGui
    if espLabelOn then
        local ok2, bb = pcall(function()
            local bg = Instance.new("BillboardGui")
            bg.Size = UDim2.new(0,120,0,36)
            bg.StudsOffset = Vector3.new(0,3,0)
            bg.AlwaysOnTop = true
            bg.Adornee = root
            bg.Parent = root

            local lbl = Instance.new("TextLabel")
            lbl.Size = UDim2.new(1,0,1,0)
            lbl.BackgroundColor3 = Color3.fromRGB(0,0,0)
            lbl.BackgroundTransparency = 0.4
            lbl.TextColor3 = col
            lbl.Text = data.name..(ms>0 and (" ["..ms.."M/s]") or "")
            lbl.TextSize = 12
            lbl.Font = Enum.Font.GothamBold
            lbl.TextWrapped = true
            lbl.Parent = bg
            Instance.new("UICorner", lbl).CornerRadius = UDim.new(0,4)

            return bg
        end)
        if ok2 then obj.bb = bb end
    end

    espObjects[model] = obj
end

local function DrawESPLines(targets)
    -- Clear previous lines
    for model, obj in pairs(espObjects) do
        if obj.line then
            pcall(function() obj.line:Remove() end)
            espObjects[model].line = nil
        end
    end

    if not espLineOn then return end

    local vpSize = camera.ViewportSize
    local origin = Vector2.new(vpSize.X / 2, vpSize.Y)  -- bottom center of screen

    for _, data in ipairs(targets) do
        local model = data.model
        local root  = data.root
        if not espObjects[model] then espObjects[model] = {} end

        local ok, line = pcall(function()
            local screenPos, onScreen, depth = WorldToViewport(root.Position)
            if not onScreen or depth < 0 then return nil end
            local col = GetESPColor(data.ms)
            local l = Drawing.new("Line")
            l.Visible = true
            l.From = origin
            l.To   = screenPos
            l.Color = col
            l.Thickness = 1.5
            l.Transparency = 0
            return l
        end)
        if ok and line then
            espObjects[model].line = line
        end
    end
end

-- Separate fast loop just for redrawing lines (positions change constantly)
local function LineDrawLoop()
    while espMasterOn do
        -- Build current target list for line drawing
        local allBrainrots = FindBrainrotsInWorkspace()
        local targets = {}
        if espHighestOnly then
            local best = nil
            for _, b in ipairs(allBrainrots) do
                if not best or b.ms > best.ms then best = b end
            end
            if best then table.insert(targets, best) end
        else
            targets = allBrainrots
        end
        DrawESPLines(targets)
        task.wait(0.05)
    end
end

local function ESPLoop()
    espRunning = true
    task.spawn(LineDrawLoop)  -- start fast line loop

    while espMasterOn do
        local allBrainrots = FindBrainrotsInWorkspace()

        -- Filter: highest only or all
        local targets = {}
        if espHighestOnly then
            local best = nil
            for _, b in ipairs(allBrainrots) do
                if not best or b.ms > best.ms then best = b end
            end
            if best then table.insert(targets, best) end
        else
            targets = allBrainrots
        end

        -- Remove ESP from models no longer in targets
        local targetSet = {}
        for _, t in ipairs(targets) do targetSet[t.model] = true end
        for model, obj in pairs(espObjects) do
            if not targetSet[model] then
                pcall(function()
                    if obj.hl  then obj.hl:Destroy()  end
                    if obj.bb  then obj.bb:Destroy()  end
                    if obj.line then obj.line:Remove() end
                end)
                espObjects[model] = nil
            end
        end

        -- Apply ESP to targets
        for _, data in ipairs(targets) do
            ApplyESPToModel(data)
        end

        -- Update ESP status label
        if #targets > 0 then
            local best = targets[1]
            for _, t in ipairs(targets) do if t.ms > best.ms then best = t end end
            ESPStatus.Text = "👁  Tracking "..#targets.." brainrot(s)  |  Best: "..best.name..(best.ms>0 and " ["..best.ms.."M/s]" or "")
            ESPStatus.TextColor3 = Color3.fromRGB(0,200,100)
        else
            ESPStatus.Text = "👁  ESP on — no brainrots found in workspace yet"
            ESPStatus.TextColor3 = Color3.fromRGB(80,130,90)
        end

        task.wait(2)
    end

    -- Cleanup when ESP turns off
    ClearAllESP()
    ESPStatus.Text = "⬤  ESP off"
    ESPStatus.TextColor3 = Color3.fromRGB(40,100,60)
    espRunning = false
end

