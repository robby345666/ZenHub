--     SCAN LOOP
-- =====================

local function ScanLoop()
    local addedKeys = {}

    while scanning do
        local brainrots = GetAllBrainrotsOnScreen()

        -- INSTANT JOIN CHECK (only if that brainrot is enabled/checked)
        for _, b in ipairs(brainrots) do
            if IsInstantJoin(b.name) then
                SetStatus("🚨 "..b.name.."! AUTO JOINING!", Color3.fromRGB(255,50,50))
                task.wait(0.15)
                InstantJoin(game.JobId, b.name)
                return
            end
        end

        -- Normal card scan
        local foundAny = false
        for _, b in ipairs(brainrots) do
            if b.ms >= targetValue and not b.instantJoin then
                local key = b.name..b.ms
                if not addedKeys[key] then
                    addedKeys[key] = true
                    AddBrainrotCard({jobId=game.JobId,name=b.name,ms=b.ms,traits=b.traits,mutations=b.mutations,imageId=b.imageId})
                    Notify("Found "..b.ms.."M/s "..b.name.."!")
                    foundAny = true
                end
            end
        end

        if foundAny then
            SetStatus("✅ Brainrots added! Still scanning...", Color3.fromRGB(0,200,100))
        elseif #brainrots > 0 then
            local best=brainrots[1]
            for _,b in ipairs(brainrots) do if b.ms>best.ms then best=b end end
            SetStatus("👁 Best: "..best.ms.."M/s — need "..targetValue.."M/s+", Color3.fromRGB(100,100,180))
        else
            SetStatus("👁 Scanning for brainrots...", Color3.fromRGB(60,150,100))
        end

        task.wait(2)
    end
end

