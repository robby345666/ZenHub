local overheadGui=nil
local function enableOverhead() if overheadGui then overheadGui:Destroy() overheadGui=nil end local c=lp.Character if not c then return end local hrp=c:WaitForChild("HumanoidRootPart") local head=c:WaitForChild("Head") local bg=Instance.new("BillboardGui") bg.Size=UDim2.new(0,100,0,18) bg.StudsOffset=Vector3.new(0,2.4,0) bg.AlwaysOnTop=true bg.Adornee=head bg.ResetOnSpawn=false bg.LightInfluence=0 bg.Parent=head local lbl=Instance.new("TextLabel") lbl.Size=UDim2.new(1,0,1,0) lbl.BackgroundTransparency=1 lbl.Text="⚡ speed: 0" lbl.TextColor3=C.yellow lbl.TextStrokeColor3=Color3.fromRGB(0,0,0) lbl.TextStrokeTransparency=0.2 lbl.TextSize=12 lbl.Font=Enum.Font.GothamBold lbl.TextXAlignment=Enum.TextXAlignment.Center lbl.Parent=bg overheadGui=bg task.spawn(function() while bg.Parent and cfg.OverheadSpeed do local vel=hrp.AssemblyLinearVelocity local spd=math.floor(Vector3.new(vel.X,0,vel.Z).Magnitude+0.5) lbl.Text="⚡ speed: "..spd task.wait(0.05) end if bg and bg.Parent then bg:Destroy() end overheadGui=nil end) end
