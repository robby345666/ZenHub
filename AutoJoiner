        rs.Color = on and Color3.fromRGB(0,80,40) or Color3.fromRGB(60,15,15)
    end
    Refresh()

    btn.MouseButton1Click:Connect(function()
        on = not on; Refresh(); callback(on)
    end)
    return btn
end

