local function FindNearestImage(obj, depth)
    depth = depth or 4
    if depth <= 0 then return nil end
    local parent = obj.Parent
    if not parent then return nil end
    for _, sib in ipairs(parent:GetChildren()) do
        if sib:IsA("ImageLabel") and sib.Image ~= "" then return sib.Image end
        for _, child in ipairs(sib:GetChildren()) do
            if child:IsA("ImageLabel") and child.Image ~= "" then return child.Image end
        end
    end
    return FindNearestImage(parent, depth - 1)
end

local function MatchTraitsAndMuts(textList)
    local traits,mutations,ts,ms = {},{},{},{}
    for _, text in ipairs(textList) do
        local tl = text:lower():gsub("^%s+",""):gsub("%s+$","")
        for key,name in pairs(MUT_SET) do
            if not ms[name] and tl:find(key,1,true) then ms[name]=true; table.insert(mutations,name) end
        end
        for key,name in pairs(TRAIT_SET) do
            if not ts[name] and tl:find(key,1,true) then ts[name]=true; table.insert(traits,name) end
        end
    end
    return traits, mutations
end

local function ScanGuiForBrainrots(root)
    local found = {}
    local function recurse(obj)
        if obj:IsA("TextLabel") or obj:IsA("TextButton") then
            local text = (obj.Text or ""):gsub("^%s+",""):gsub("%s+$","")
            if #text > 2 and #text < 80 and IsInstantJoin(text) then
                table.insert(found,{ms=0,name=text,traits={},mutations={},imageId="",instantJoin=true})
            end
            if #text <= 20 then
                local raw = text:match("^([%d%.]+)%s*[Mm]%s*/%s*[Ss]$")
                if raw then
                    local val = tonumber(raw)
                    if val and val >= 1 and val <= 999 then
                        local parent = obj.Parent
                        local name = "Unknown Brainrot"
                        local imageId = FindNearestImage(obj,4) or ""
                        local siblingTexts = {}
                        if parent then
                            for _, sib in ipairs(parent:GetChildren()) do
                                if sib ~= obj and (sib:IsA("TextLabel") or sib:IsA("TextButton")) then
                                    local t = (sib.Text or ""):gsub("^%s+",""):gsub("%s+$","")
                                    if #t > 1 then
                                        table.insert(siblingTexts,t)
                                        if #t < 60 and not t:match("^[%d%.]+") and not t:match("[Mm]/%s*[Ss]") then
                                            local tl = t:lower()
                                            local isKnown = false
                                            for key in pairs(TRAIT_SET) do if tl:find(key,1,true) then isKnown=true; break end end
                                            if not isKnown then for key in pairs(MUT_SET) do if tl:find(key,1,true) then isKnown=true; break end end end
                                            if not isKnown and name=="Unknown Brainrot"
                                                and not tl:match("join") and not tl:match("steal") and not tl:match("server") then
                                                name = t
                                            end
                                        end
                                    end
                                end
                            end
                        end
                        if imageId == "" then
                            local nl = name:lower()
                            imageId = BRAINROT_IMAGES[nl] or ""
                        end
                        local traits, mutations = MatchTraitsAndMuts(siblingTexts)
                        table.insert(found,{ms=val,name=name,traits=traits,mutations=mutations,imageId=imageId})
                    end
                end
            end
        end
        for _, child in ipairs(obj:GetChildren()) do recurse(child) end
    end
    recurse(root)
    return found
end

local function GetAllBrainrotsOnScreen()
    local all, seen = {}, {}
    for _, gui in ipairs(PlayerGui:GetChildren()) do
        if gui.Name ~= "BrainrotJoinerGui" and gui.Name ~= "BrainrotSplash" then
            for _, r in ipairs(ScanGuiForBrainrots(gui)) do
                local key = r.ms..r.name
                if not seen[key] then seen[key]=true; table.insert(all,r) end
            end
        end
    end
    pcall(function()
        for _, gui in ipairs(game:GetService("CoreGui"):GetChildren()) do
            for _, r in ipairs(ScanGuiForBrainrots(gui)) do
                local key = r.ms..r.name
                if not seen[key] then seen[key]=true; table.insert(all,r) end
            end
        end
    end)
    return all
end

