-- ── Drop BR ── (fast up, fast down, no character reset)
local dropping=false
local function enableDropBR()
    if dropping then return end dropping=true
    local c=lp.Character if not c then dropping=false return end
    local hrp=c:FindFirstChild("HumanoidRootPart") if not hrp then dropping=false return end
    local hum=c:FindFirstChildOfClass("Humanoid") if not hum then dropping=false return end
    task.spawn(function()
        -- disable fall damage state so landing doesn't kill character
        pcall(function() hum:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false) end)
        pcall(function() hum:SetStateEnabled(Enum.HumanoidStateType.GettingUp, false) end)

        -- keep health maxed during the whole move
        local healthConn=RunService.RenderStepped:Connect(function()
            pcall(function() if hum.Health < hum.MaxHealth then hum.Health = hum.MaxHealth end end)
        end)

        -- blast up with BodyVelocity
        local bv=Instance.new("BodyVelocity")
        bv.Velocity=Vector3.new(0,200,0) bv.MaxForce=Vector3.new(0,1e7,0) bv.P=1e6
        bv.Parent=hrp
        task.wait(0.12)
        bv:Destroy()

        -- fire drop remotes at the peak
        fireRemote("drop") fireRemote("unequip") fireRemote("release")
        pcall(function() hum:UnequipTools() end)

        -- slam back down with BodyVelocity
        task.wait(0.08)
        local bvDown=Instance.new("BodyVelocity")
        bvDown.Velocity=Vector3.new(0,-200,0) bvDown.MaxForce=Vector3.new(0,1e7,0) bvDown.P=1e6
        bvDown.Parent=hrp
        task.wait(0.15)
        bvDown:Destroy()

        -- wait to land then cleanup
        task.wait(0.3)
        healthConn:Disconnect()
        pcall(function() hum:SetStateEnabled(Enum.HumanoidStateType.FallingDown, true) end)
        pcall(function() hum:SetStateEnabled(Enum.HumanoidStateType.GettingUp, true) end)

        dropping=false cfg.DropBR=false
        if setters.DropBR then setters.DropBR(false,true) end
    end)
end

