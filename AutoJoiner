--  SPEED LOOP
-- ════════════════════════════════════
RunService.Heartbeat:Connect(function()
    local c=lp.Character if not c then return end
    local hum=c:FindFirstChildOfClass("Humanoid") local hrp=c:FindFirstChild("HumanoidRootPart")
    if not hum or not hrp then return end
    -- CarrySpeed overrides everything
    if cfg.CarrySpeed then
        pcall(function() hum.WalkSpeed=30 end)
        return
    end
    -- Speed boost: set WalkSpeed directly (works with all games)
    if cfg.SpeedBoost then
        pcall(function() hum.WalkSpeed=cfg.Speed end)
    elseif cfg.StealBoost then
        pcall(function() hum.WalkSpeed=cfg.Steal end)
    end
    -- Also push via velocity for games that reset WalkSpeed
    local spd = cfg.StealBoost and cfg.Steal or (cfg.SpeedBoost and cfg.Speed or 0)
    if spd > 0 and hum.MoveDirection.Magnitude > 0 then
        local md = hum.MoveDirection
        hrp.AssemblyLinearVelocity = Vector3.new(md.X*spd, hrp.AssemblyLinearVelocity.Y, md.Z*spd)
    end
end)

