local twS=TweenInfo.new(0.15,Enum.EasingStyle.Quad,Enum.EasingDirection.Out)
local function mkSideBtn(txt, icon, yOff)
    -- Each button lives directly on screenGui so it can be dragged freely
    local btn=Instance.new("TextButton",screenGui)
    btn.Size=UDim2.new(0,44,0,44)
    btn.Position=UDim2.new(1,-58,0,yOff+8)   -- initial position mirrors old SS layout
    btn.BackgroundColor3=Color3.fromRGB(12,12,16) btn.BorderSizePixel=0 btn.AutoButtonColor=false btn.Text=""
    btn.ZIndex=200
    Instance.new("UICorner",btn).CornerRadius=UDim.new(0,9)
    local sk=Instance.new("UIStroke",btn) sk.Color=Color3.fromRGB(35,35,40) sk.Thickness=1.5
    local il=Instance.new("TextLabel",btn) il.Size=UDim2.new(1,0,0,20) il.Position=UDim2.new(0,0,0,4)
    il.BackgroundTransparency=1 il.Text=icon il.TextSize=16 il.TextXAlignment=Enum.TextXAlignment.Center il.ZIndex=201
    local lb=Instance.new("TextLabel",btn) lb.Size=UDim2.new(1,-2,0,18) lb.Position=UDim2.new(0,1,0,24)
    lb.BackgroundTransparency=1 lb.Text=txt lb.TextColor3=Color3.fromRGB(180,180,180)
    lb.TextSize=6.5 lb.Font=Enum.Font.GothamBold lb.TextWrapped=true lb.TextXAlignment=Enum.TextXAlignment.Center lb.ZIndex=201
    local dot=Instance.new("Frame",btn) dot.Size=UDim2.new(0,6,0,6) dot.Position=UDim2.new(1,-9,0,3)
    dot.BackgroundColor3=Color3.fromRGB(40,40,45) dot.BorderSizePixel=0 dot.ZIndex=202
    Instance.new("UICorner",dot).CornerRadius=UDim.new(1,0)

    -- drag each button individually
    drag(btn)

    local function activate(on)
        TweenService:Create(sk,twS,{Color=on and C.yellow or Color3.fromRGB(35,35,40)}):Play()
        TweenService:Create(lb,twS,{TextColor3=on and C.white or Color3.fromRGB(180,180,180)}):Play()
        TweenService:Create(dot,twS,{BackgroundColor3=on and C.yellow or Color3.fromRGB(40,40,45)}):Play()
    end
    return btn, activate
end

