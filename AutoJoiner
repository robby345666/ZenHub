local function mkToggle(parent, name, icon, xOff, yOff, cb)
    local f=Instance.new("Frame",parent)
    f.Size=UDim2.new(0,168,0,38) f.Position=UDim2.new(0,xOff,0,yOff)
    f.BackgroundColor3=C.row f.BorderSizePixel=0
    Instance.new("UICorner",f).CornerRadius=UDim.new(0,8)
    local sk=Instance.new("UIStroke",f) sk.Color=C.strokeOff sk.Thickness=1

    local il=Instance.new("TextLabel",f) il.Size=UDim2.new(0,24,0,24)
    il.Position=UDim2.new(0,6,0,7) il.BackgroundTransparency=1
    il.Text=icon il.TextSize=15 il.TextColor3=C.white il.TextXAlignment=Enum.TextXAlignment.Center

    local nl=Instance.new("TextLabel",f) nl.Size=UDim2.new(0,88,0,38)
    nl.Position=UDim2.new(0,34,0,0) nl.BackgroundTransparency=1
    nl.Text=name nl.TextColor3=C.text nl.TextSize=10 nl.Font=Enum.Font.GothamMedium
    nl.TextXAlignment=Enum.TextXAlignment.Left

    local tog=Instance.new("TextButton",f)
    tog.Size=UDim2.new(0,42,0,22) tog.Position=UDim2.new(1,-48,0,8)
    tog.BackgroundColor3=C.togOff tog.BorderSizePixel=0 tog.Text=""
    Instance.new("UICorner",tog).CornerRadius=UDim.new(1,0)
    local knob=Instance.new("Frame",tog)
    knob.Size=UDim2.new(0,16,0,16) knob.Position=UDim2.new(0,3,0.5,-8)
    knob.BackgroundColor3=C.knobOff knob.BorderSizePixel=0
    Instance.new("UICorner",knob).CornerRadius=UDim.new(1,0)

    local on=false
    local ti=TweenInfo.new(0.18,Enum.EasingStyle.Quart,Enum.EasingDirection.Out)
    local function set(v,skip)
        on=v
        if on then
            TweenService:Create(tog,ti,{BackgroundColor3=C.togOn}):Play()
            TweenService:Create(knob,ti,{Position=UDim2.new(1,-19,0.5,-8),BackgroundColor3=C.knobOn}):Play()
            TweenService:Create(sk,ti,{Color=C.strokeOn}):Play()
        else
            TweenService:Create(tog,ti,{BackgroundColor3=C.togOff}):Play()
            TweenService:Create(knob,ti,{Position=UDim2.new(0,3,0.5,-8),BackgroundColor3=C.knobOff}):Play()
            TweenService:Create(sk,ti,{Color=C.strokeOff}):Play()
        end
        if not skip then cb(on) end
    end
    tog.MouseButton1Click:Connect(function() set(not on) end)
    return set
end

