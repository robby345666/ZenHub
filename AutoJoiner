-- ── fireRemote ──
local function fireRemote(kw)
    pcall(function() for _,r in pairs(workspace:GetDescendants()) do if r:IsA("RemoteEvent") and r.Name:lower():find(kw) then r:FireServer() end end end)
    pcall(function() for _,r in pairs(ReplicatedStorage:GetDescendants()) do if r:IsA("RemoteEvent") and r.Name:lower():find(kw) then r:FireServer() end end end)
end

