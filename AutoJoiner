local function applyHitbox(p) if p==lp then return end local c=p.Character if not c then return end local hrp=c:FindFirstChild("HumanoidRootPart") if not hrp then return end pcall(function() hrp.Size=Vector3.new(cfg.HitboxSize,cfg.HitboxSize,cfg.HitboxSize) end) end
local function removeHitbox(p) if p.Character then local hrp=p.Character:FindFirstChild("HumanoidRootPart") if hrp then pcall(function() hrp.Size=Vector3.new(2,2,1) end) end end end
local function enableHitbox() if hitboxC then hitboxC:Disconnect() hitboxC=nil end for _,p in ipairs(Players:GetPlayers()) do if p~=lp then applyHitbox(p) p.CharacterAdded:Connect(function() task.wait(0.5) if cfg.HitboxExpander then applyHitbox(p) end end) end end hitboxC=Players.PlayerAdded:Connect(function(p) p.CharacterAdded:Connect(function() task.wait(0.5) if cfg.HitboxExpander then applyHitbox(p) end end) end) task.spawn(function() while cfg.HitboxExpander do for _,p in ipairs(Players:GetPlayers()) do if p~=lp and p.Character then local hrp=p.Character:FindFirstChild("HumanoidRootPart") if hrp then pcall(function() if hrp.Size.X<cfg.HitboxSize then hrp.Size=Vector3.new(cfg.HitboxSize,cfg.HitboxSize,cfg.HitboxSize) end end) end end end task.wait(0.5) end end) end
local function disableHitbox() if hitboxC then hitboxC:Disconnect() hitboxC=nil end for _,p in ipairs(Players:GetPlayers()) do removeHitbox(p) end end

