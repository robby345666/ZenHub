-- Build enabled lookup (updates live when checkboxes toggled)
local function BuildInstantSet()
    local set = {}
    for _, entry in ipairs(RARE_LIST) do
        if entry.enabled then
            set[entry.name:lower()] = true
        end
    end
    return set
end

local instantSet = BuildInstantSet()

local function IsInstantJoin(name)
    if not name then return false end
    local nl = name:lower():gsub("^%s+",""):gsub("%s+$","")
    if instantSet[nl] then return true end
    for key in pairs(instantSet) do
        if nl:find(key, 1, true) or key:find(nl, 1, true) then
            return true
        end
    end
    return false
end

