local function mkNum(parent, name, xOff, yOff, default, minV, maxV, cb)
    local f=Instance.new("Frame",parent)
    f.Size=UDim2.new(0,168,0,38) f.Position=UDim2.new(0,xOff,0,yOff)
    f.BackgroundColor3=C.row f.BorderSizePixel=0
    Instance.new("UICorner",f).CornerRadius=UDim.new(0,8)
    local sk=Instance.new("UIStroke",f) sk.Color=C.strokeOff sk.Thickness=1

    local nl=Instance.new("TextLabel",f) nl.Size=UDim2.new(0,96,0,38)
    nl.Position=UDim2.new(0,8,0,0) nl.BackgroundTransparency=1
    nl.Text=name nl.TextColor3=C.text nl.TextSize=10 nl.Font=Enum.Font.GothamMedium
    nl.TextXAlignment=Enum.TextXAlignment.Left

    local box=Instance.new("TextBox",f)
    box.Size=UDim2.new(0,58,0,24) box.Position=UDim2.new(1,-64,0.5,-12)
    box.BackgroundColor3=C.numBg box.Text=tostring(default)
    box.TextColor3=C.yellow box.PlaceholderColor3=Color3.fromRGB(80,80,90)
    box.TextSize=11 box.Font=Enum.Font.GothamBold
    box.TextXAlignment=Enum.TextXAlignment.Center box.ClearTextOnFocus=false
    box.BorderSizePixel=0
    Instance.new("UICorner",box).CornerRadius=UDim.new(0,6)
    local bs=Instance.new("UIStroke",box) bs.Color=C.numStroke bs.Thickness=1

    local cur=default
    local function applyVal()
        local n=tonumber(box.Text)
        if n then
            cur=math.clamp(n,minV,maxV) box.Text=tostring(cur)
            TweenService:Create(bs,TweenInfo.new(0.15),{Color=C.yellow}):Play()
            TweenService:Create(sk,TweenInfo.new(0.15),{Color=C.yellow}):Play()
            task.delay(0.5,function()
                TweenService:Create(bs,TweenInfo.new(0.3),{Color=C.numStroke}):Play()
                TweenService:Create(sk,TweenInfo.new(0.3),{Color=C.strokeOff}):Play()
            end)
            cb(cur)
        else
            box.Text=tostring(cur)
            TweenService:Create(bs,TweenInfo.new(0.15),{Color=Color3.fromRGB(200,50,50)}):Play()
            task.delay(0.4,function() TweenService:Create(bs,TweenInfo.new(0.3),{Color=C.numStroke}):Play() end)
        end
    end
    box.Focused:Connect(function()
        TweenService:Create(bs,TweenInfo.new(0.12),{Color=C.yellow}):Play()
        TweenService:Create(sk,TweenInfo.new(0.12),{Color=C.yellow}):Play()
    end)
    box.FocusLost:Connect(applyVal)
end

