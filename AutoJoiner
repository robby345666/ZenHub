-- ── Auto Steal ──
local stealActive=false local stealConn=nil local stealCache={} local stealPromptCache={} local stealCBCache={} local stealStealing=false
local animData={} pcall(function() animData=require(ReplicatedStorage:WaitForChild("Datas",5):WaitForChild("Animals",5)) end)
local function sGetHRP() local c=lp.Character if not c then return nil end return c:FindFirstChild("HumanoidRootPart") end
local function sIsMyBase(n) local pl=workspace:FindFirstChild("Plots") local p=pl and pl:FindFirstChild(n) if not p then return false end local s=p:FindFirstChild("PlotSign") if not s then return false end local y=s:FindFirstChild("YourBase") if y and y:IsA("BillboardGui") then return y.Enabled end return false end
local function sScanPlot(plot) if not plot or not plot:IsA("Model") then return end if sIsMyBase(plot.Name) then return end local pods=plot:FindFirstChild("AnimalPodiums") if not pods then return end for _,pod in ipairs(pods:GetChildren()) do if pod:IsA("Model") and pod:FindFirstChild("Base") then local a="Unknown" local sp=pod.Base:FindFirstChild("Spawn") if sp then for _,ch in ipairs(sp:GetChildren()) do if ch:IsA("Model") and ch.Name~="PromptAttachment" then a=ch.Name local info=animData[a] if info and info.DisplayName then a=info.DisplayName end break end end end table.insert(stealCache,{name=a,plot=plot.Name,slot=pod.Name,wp=pod:GetPivot().Position,uid=plot.Name.."_"..pod.Name}) end end end
local sScanned=false
local function sInitScan() if sScanned then return end sScanned=true task.spawn(function() task.wait(2) local pl=workspace:WaitForChild("Plots",10) if not pl then return end for _,p in ipairs(pl:GetChildren()) do if p:IsA("Model") then sScanPlot(p) end end pl.ChildAdded:Connect(function(p) if p:IsA("Model") then task.wait(0.5) sScanPlot(p) end end) task.spawn(function() while task.wait(5) do stealCache={} for _,p in ipairs(pl:GetChildren()) do if p:IsA("Model") then sScanPlot(p) end end end end) end) end
local _gc=rawget(_G,"getconnections")
local function sBuildCB(pr) if stealCBCache[pr] then return end local d={hcb={},tcb={},ready=true} if _gc then local ok1,c1=pcall(_gc,pr.PromptButtonHoldBegan) if ok1 and type(c1)=="table" then for _,c in ipairs(c1) do if type(c.Function)=="function" then table.insert(d.hcb,c.Function) end end end local ok2,c2=pcall(_gc,pr.Triggered) if ok2 and type(c2)=="table" then for _,c in ipairs(c2) do if type(c.Function)=="function" then table.insert(d.tcb,c.Function) end end end end if #d.hcb>0 or #d.tcb>0 then stealCBCache[pr]=d end end
local function sExec(pr) local d=stealCBCache[pr] if not d or not d.ready then return false end d.ready=false stealStealing=true task.spawn(function() for _,f in ipairs(d.hcb) do task.spawn(f) end task.wait(0.2) for _,f in ipairs(d.tcb) do task.spawn(f) end task.wait(0.01) d.ready=true task.wait(0.01) stealStealing=false end) return true end
local function sFindPrompt(a) if not a then return nil end local c=stealPromptCache[a.uid] if c and c.Parent then return c end local pl=workspace:FindFirstChild("Plots") local p=pl and pl:FindFirstChild(a.plot) if not p then return nil end local pods=p:FindFirstChild("AnimalPodiums") local pod=pods and pods:FindFirstChild(a.slot) if not pod then return nil end local base=pod:FindFirstChild("Base") local sp=base and base:FindFirstChild("Spawn") local att=sp and sp:FindFirstChild("PromptAttachment") if not att then return nil end for _,pr in ipairs(att:GetChildren()) do if pr:IsA("ProximityPrompt") then stealPromptCache[a.uid]=pr return pr end end return nil end
local function sGetNearest() local hrp=sGetHRP() if not hrp then return nil end local best,md=nil,math.huge for _,a in ipairs(stealCache) do if not sIsMyBase(a.plot) and a.wp then local d=(hrp.Position-a.wp).Magnitude if d<md then md=d best=a end end end return best end
local function startStealLoop() if stealConn then stealConn:Disconnect() end stealConn=RunService.Heartbeat:Connect(function() if not stealActive or stealStealing then return end local t=sGetNearest() if not t or not t.wp then return end local hrp=sGetHRP() if not hrp then return end if (hrp.Position-t.wp).Magnitude>cfg.GrabRadius then return end local pr=stealPromptCache[t.uid] if not pr or not pr.Parent then pr=sFindPrompt(t) end if pr then sBuildCB(pr) if stealCBCache[pr] then sExec(pr) end end end) end
local function stopStealLoop() if stealConn then stealConn:Disconnect() stealConn=nil end stealStealing=false end
local function enableSteal() stealActive=true sInitScan() startStealLoop() end
local function disableSteal() stealActive=false stopStealLoop() end

-- ── Circle for steal/duel ──
local circleParts={} local PC=65
local function createCircle() for _,p in ipairs(circleParts) do pcall(function() p:Destroy() end) end table.clear(circleParts) for i=1,PC do local p=Instance.new("Part") p.Anchored=true p.CanCollide=false p.Material=Enum.Material.Neon p.Color=C.yellow p.Transparency=0.35 p.Size=Vector3.new(1,0.2,0.3) p.Parent=workspace table.insert(circleParts,p) end end
RunService.RenderStepped:Connect(function() if not cfg.AutoSteal and not cfg.AutoDuel then return end local hrp=sGetHRP() if not hrp then return end if #circleParts==0 then createCircle() end for i,p in ipairs(circleParts) do local a1=math.rad((i-1)/PC*360) local a2=math.rad(i/PC*360) local p1=Vector3.new(math.cos(a1),0,math.sin(a1))*cfg.GrabRadius local p2=Vector3.new(math.cos(a2),0,math.sin(a2))*cfg.GrabRadius local c=(p1+p2)/2+hrp.Position p.Size=Vector3.new((p2-p1).Magnitude,0.2,0.3) p.CFrame=CFrame.new(c,c+Vector3.new(p2.X-p1.X,0,p2.Z-p1.Z))*CFrame.Angles(0,math.pi/2,0) end end)

-- ── Auto Duel ──
local duelPath={} local duelIdx=1 local duelMoving=false local duelConn=nil local duelPend=false
local function startDuel() local root=lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") if not root then return end duelMoving=true duelPend=false if (root.Position-Vector3.new(-475,-7,96)).Magnitude>(root.Position-Vector3.new(-474,-7,23)).Magnitude then duelPath={{position=Vector3.new(-475,-7,96),speed=59},{position=Vector3.new(-483,-5,95),speed=59},{position=Vector3.new(-487,-5,95),speed=55},{position=Vector3.new(-492,-5,95),speed=55},{position=Vector3.new(-473,-7,95),speed=29},{position=Vector3.new(-473,-7,11),speed=29}} else duelPath={{position=Vector3.new(-474,-7,23),speed=55},{position=Vector3.new(-484,-5,24),speed=55},{position=Vector3.new(-488,-5,24),speed=55},{position=Vector3.new(-493,-5,25),speed=55},{position=Vector3.new(-473,-7,25),speed=29},{position=Vector3.new(-474,-7,112),speed=29}} end duelIdx=1 if duelConn then duelConn:Disconnect() end duelConn=RunService.Stepped:Connect(function() if not cfg.AutoDuel or not duelMoving then return end local c=lp.Character local r=c and c:FindFirstChild("HumanoidRootPart") if not r then return end local wp=duelPath[duelIdx] if not wp then duelMoving=false return end local dist=(r.Position-wp.position).Magnitude local stop=duelIdx==#duelPath and 1.2 or 2.5 if dist<stop then if duelIdx==#duelPath then r.AssemblyLinearVelocity=Vector3.zero if not duelPend then duelPend=true task.delay(0.8,function() if not cfg.AutoDuel then return end duelIdx=1 duelPend=false end) end else duelIdx=duelIdx+1 end else local dir=(wp.position-r.Position).Unit local spd=wp.speed if duelIdx==#duelPath and dist<8 then spd=math.max(12,spd*(dist/8)) end r.AssemblyLinearVelocity=Vector3.new(dir.X*spd,r.AssemblyLinearVelocity.Y,dir.Z*spd) end end) end
local function stopDuel() duelMoving=false duelPend=false if duelConn then duelConn:Disconnect() duelConn=nil end local r=lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") if r then r.AssemblyLinearVelocity=Vector3.zero end end

-- ── Auto Left / Right paths ──
local pathActive=false local lastFlat=Vector3.zero local alEnabled=false local arEnabled=false
local sp1={{pos=Vector3.new(-470.6,-5.9,34.4)},{pos=Vector3.new(-484.2,-3.9,21.4)},{pos=Vector3.new(-475.6,-5.8,29.3)},{pos=Vector3.new(-473.4,-5.9,111.0)}}
local sp2={{pos=Vector3.new(-474.7,-5.9,91.0)},{pos=Vector3.new(-483.4,-3.9,97.3)},{pos=Vector3.new(-474.7,-5.9,91.0)},{pos=Vector3.new(-476.1,-5.5,25.4)}}
local function pathMove(hrp,cur,nxt,spd) local conn conn=RunService.Heartbeat:Connect(function() if not pathActive then conn:Disconnect() hrp.AssemblyLinearVelocity=Vector3.zero return end local pos=hrp.Position local tgt=Vector3.new(cur.X,pos.Y,cur.Z) local dir=tgt-pos local dist=dir.Magnitude if dist<=1.35 then conn:Disconnect() hrp.AssemblyLinearVelocity=Vector3.zero return end local md=dir.Unit if nxt then local nd=(Vector3.new(nxt.X,pos.Y,nxt.Z)-pos).Unit md=(md+nd*0.45).Unit end if lastFlat.Magnitude>0.1 then md=(md*0.88+lastFlat.Unit*0.12).Unit end local vel=Vector3.new(md.X*spd,hrp.AssemblyLinearVelocity.Y,md.Z*spd) hrp.AssemblyLinearVelocity=vel lastFlat=Vector3.new(vel.X,0,vel.Z) end) while pathActive and (Vector3.new(hrp.Position.X,0,hrp.Position.Z)-Vector3.new(cur.X,0,cur.Z)).Magnitude>1.35 do RunService.Heartbeat:Wait() end end
local function runPath(sp) local hrp=(lp.Character or lp.CharacterAdded:Wait()):WaitForChild("HumanoidRootPart") for i,p in ipairs(sp) do if not pathActive then return end local spd=i>2 and 29.6 or 59.2 pathMove(hrp,p.pos,sp[i+1] and sp[i+1].pos,spd) if i==2 then task.wait(0.2) else task.wait(0.01) end end end
local function startPath(sp) pathActive=true task.spawn(function() while pathActive do runPath(sp) task.wait(0.1) end end) end
local function stopPath() pathActive=false lastFlat=Vector3.zero local hrp=lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") if hrp then hrp.AssemblyLinearVelocity=Vector3.zero end end
local function enableAutoLeft() if arEnabled then stopPath() arEnabled=false cfg.AutoRight=false if setters.AutoRight then setters.AutoRight(false,true) end acRight(false) end alEnabled=true cfg.AutoLeft=true startPath(sp2) acLeft(true) if setters.AutoLeft then setters.AutoLeft(true,true) end end
local function disableAutoLeft() alEnabled=false cfg.AutoLeft=false stopPath() acLeft(false) end
local function enableAutoRight() if alEnabled then stopPath() alEnabled=false cfg.AutoLeft=false if setters.AutoLeft then setters.AutoLeft(false,true) end acLeft(false) end arEnabled=true cfg.AutoRight=true startPath(sp1) acRight(true) if setters.AutoRight then setters.AutoRight(true,true) end end
local function disableAutoRight() arEnabled=false cfg.AutoRight=false stopPath() acRight(false) end

-- ── Anti Ragdoll ──
local arMode=nil local arConns={} local arChar={} local arBoosting=false
local function arCache() local c=lp.Character if not c then return false end local hum=c:FindFirstChildOfClass("Humanoid") local root=c:FindFirstChild("HumanoidRootPart") if not hum or not root then return false end arChar={c=c,h=hum,r=root} return true end
local function arDisconn() for _,v in ipairs(arConns) do pcall(function() v:Disconnect() end) end arConns={} end
local function arIsRag() if not arChar.h then return false end local s=arChar.h:GetState() if s==Enum.HumanoidStateType.Physics or s==Enum.HumanoidStateType.Ragdoll or s==Enum.HumanoidStateType.FallingDown then return true end local et=lp:GetAttribute("RagdollEndTime") if et then local sn=0 pcall(function() sn=workspace:GetServerTimeNow() end) if (et-sn)>0 then return true end end return false end
local function arExit() if not arChar.h or not arChar.r then return end pcall(function() local sn=0 pcall(function() sn=workspace:GetServerTimeNow() end) lp:SetAttribute("RagdollEndTime",sn) end) for _,d in ipairs(arChar.c:GetDescendants()) do if d:IsA("BallSocketConstraint") or (d:IsA("Attachment") and d.Name:find("RagdollAttachment")) then d:Destroy() end end if not arBoosting then arBoosting=true arChar.h.WalkSpeed=400 end if arChar.h.Health>0 then arChar.h:ChangeState(Enum.HumanoidStateType.Running) end arChar.r.Anchored=false end
local function arLoop() while arMode=="on" do task.wait() if arIsRag() then arExit() elseif arBoosting then arBoosting=false if arChar.h then arChar.h.WalkSpeed=16 end end end end
local function enableAntiRag() if arMode=="on" then return end if not arCache() then return end arMode="on" table.insert(arConns,RunService.RenderStepped:Connect(function() local cam=workspace.CurrentCamera if cam and arChar.h then cam.CameraSubject=arChar.h end end)) table.insert(arConns,lp.CharacterAdded:Connect(function() arBoosting=false task.wait(0.5) arCache() end)) task.spawn(arLoop) end
local function disableAntiRag() arMode=nil if arBoosting and arChar.h then arChar.h.WalkSpeed=16 end arBoosting=false arDisconn() arChar={} end

