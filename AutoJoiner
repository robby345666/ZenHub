    local function Refresh()
        btn.Text = on and "ON" or "OFF"
        btn.BackgroundColor3 = on and Color3.fromRGB(0,110,55) or Color3.fromRGB(80,15,15)
        btn.TextColor3 = on and Color3.fromRGB(180,255,210) or Color3.fromRGB(255,80,80)
