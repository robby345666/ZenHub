-- Current scale (0.5 = 50% of slider = 1.0 actual scale since range is 0.6–1.6)
local currentScale = 1.0
local SCALE_MIN = 0.6
local SCALE_MAX = 1.6

local function ApplyScale(s)
    currentScale = math.clamp(s, SCALE_MIN, SCALE_MAX)
    local pct = (currentScale - SCALE_MIN) / (SCALE_MAX - SCALE_MIN)
    sliderFill.Size = UDim2.new(pct, 0, 1, 0)
    sliderKnob.Position = UDim2.new(pct, -9, 0.5, -9)
    scaleValLbl.Text = math.floor(currentScale * 100 + 0.5) .. "%"
    -- Resize the ScreenGui root frame
    MainFrame.Size = UDim2.new(0, math.floor(540 * currentScale), 0, math.floor(600 * currentScale))
end

