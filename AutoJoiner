local function enableMelee() if MA.on then return end MA.on=true local char=lp.Character or lp.CharacterAdded:Wait() local hrp=char:WaitForChild("HumanoidRootPart") MA.att=Instance.new("Attachment",hrp) MA.align=Instance.new("AlignOrientation",hrp) MA.align.Attachment0=MA.att MA.align.Mode=Enum.OrientationAlignmentMode.OneAttachment MA.align.RigidityEnabled=true local r=cfg.MeleeRadius local cp=Instance.new("Part") cp.Shape=Enum.PartType.Cylinder cp.Material=Enum.Material.Neon cp.Size=Vector3.new(0.05,r*2,r*2) cp.Color=C.yellow cp.CanCollide=false cp.Massless=true cp.Transparency=0.4 cp.Parent=workspace local w=Instance.new("Weld") w.Part0=hrp w.Part1=cp w.C0=CFrame.new(0,-1,0)*CFrame.Angles(0,0,math.rad(90)) w.Parent=cp MA.circ=cp MA.conn=RunService.RenderStepped:Connect(function() if not MA.on then return end local c=lp.Character if not c then return end local h=c:FindFirstChild("HumanoidRootPart") local hum=c:FindFirstChildOfClass("Humanoid") if not h or not hum then return end local best,bd=nil,cfg.MeleeRadius for _,p in ipairs(Players:GetPlayers()) do if p~=lp and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then local d=(p.Character.HumanoidRootPart.Position-h.Position).Magnitude if d<=bd then bd=d best=p.Character.HumanoidRootPart end end end if best then hum.AutoRotate=false MA.align.Enabled=true pcall(function() MA.align.CFrame=CFrame.lookAt(h.Position,Vector3.new(best.Position.X,h.Position.Y,best.Position.Z)) end) local t=c:FindFirstChild("Bat") or c:FindFirstChild("Medusa") if t then pcall(function() t:Activate() end) end else MA.align.Enabled=false hum.AutoRotate=true end end) end
local function disableMelee() if not MA.on then return end MA.on=false if MA.conn then MA.conn:Disconnect() MA.conn=nil end if MA.circ then MA.circ:Destroy() MA.circ=nil end if MA.align then MA.align:Destroy() MA.align=nil end if MA.att then MA.att:Destroy() MA.att=nil end local hum=lp.Character and lp.Character:FindFirstChildOfClass("Humanoid") if hum then hum.AutoRotate=true end end

